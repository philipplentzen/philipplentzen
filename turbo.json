{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [".env", "pnpm-lock.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "out/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "env": ["NEXT_PUBLIC_IS_E2E"],
      "passThroughEnv": ["PLAYWRIGHT_*"],
      "dependsOn": ["build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "tests/**/*.spec.ts",
        "playwright.config.ts"
      ]
    },
    "//#format": {
      "cache": false
    }
  }
}
